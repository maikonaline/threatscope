# ThreatScope — Variables de entorno
# Copiar a .env y rellenar los valores reales
# NUNCA subir .env a Git (ya esta en .gitignore)

# ─── ENTORNO ───────────────────────────────────────────────────────────────
THREATSCOPE_ENV=development          # development | production
THREATSCOPE_DEBUG=false              # true solo en desarrollo
THREATSCOPE_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ─── BASE DE DATOS ─────────────────────────────────────────────────────────
THREATSCOPE_DB_ENGINE=sqlite         # sqlite (dev) | postgresql (prod)
THREATSCOPE_DB_PATH=./data/threatscope.db   # Solo para sqlite

# Solo si DB_ENGINE=postgresql:
# THREATSCOPE_DB_HOST=localhost
# THREATSCOPE_DB_PORT=5432
# THREATSCOPE_DB_USER=threatscope
# THREATSCOPE_DB_PASS=tu_password_aqui
# THREATSCOPE_DB_NAME=threatscope

# ─── THREAT INTELLIGENCE (opcionales) ──────────────────────────────────────
# Sin estas claves el sistema usa heuristicas. Con ellas, precision maxima.
# ABUSEIPDB_API_KEY=tu_clave_aqui
# VIRUSTOTAL_API_KEY=tu_clave_aqui
IPWHOIS_TIMEOUT=10                   # Timeout en segundos para ipwho.is

# ─── MODELO ML ─────────────────────────────────────────────────────────────
ML_CONTAMINATION=0.05                # % anomalias esperadas (0.01 - 0.20)
ML_N_ESTIMATORS=100                  # Arboles de Isolation Forest
ML_RANDOM_STATE=42                   # Semilla para reproducibilidad

# ─── EJECUCION ─────────────────────────────────────────────────────────────
THREATSCOPE_BATCH_SIZE=1000          # Eventos por batch
THREATSCOPE_WORKERS=4                # Workers paralelos
